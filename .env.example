# SMTP used by /api/callback for contact + callback forms.
# REQUIRED — app returns 503 if SMTP_USER/SMTP_PASS/CALLBACK_TO are missing.
# On Vercel: scope these to "Production" only (uncheck Preview, Development)
# to prevent preview URLs from sending real email via production credentials.

SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=yut.klintsi@yandex.ru
SMTP_PASS=your_app_password_here
SMTP_FROM="Гостиница Уют <yut.klintsi@yandex.ru>"
CALLBACK_TO=yut.klintsi@yandex.ru
